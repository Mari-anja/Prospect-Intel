# Copy to .env.local and fill in.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Supabase Postgres connection string, used by Drizzle) ---
# Get from: Supabase dashboard > Project Settings > Database > Connection string > URI
# Prefer the "Transaction" pooler URL for serverless.
DATABASE_URL=

# --- App secrets ---
# 32-byte key used to encrypt user-provided API keys at rest.
# Generate with: openssl rand -base64 32
KEY_ENCRYPTION_MASTER_KEY=

# --- App config ---
# Canonical URL of the deployment, used for OAuth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3020
